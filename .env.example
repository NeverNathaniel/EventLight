# ─────────────────────────────────────────────────────────────
# EventLight configuration
# Copy this file to `.env` and fill in your keys.
# Never commit your real .env — it is gitignored.
# ─────────────────────────────────────────────────────────────

# Server
PORT=3000

# Timezone for date logic ("Tonight", "This Week"). Mainly relevant in Docker,
# where the container defaults to UTC. Use a TZ database name.
TZ=America/Los_Angeles

# ── API keys ──────────────────────────────────────────────────
# Ticketmaster Discovery API consumer key
# https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=

# Bandsintown App ID
# https://artists.bandsintown.com/support/api-installation
BANDSINTOWN_APP_ID=

# Eventbrite private OAuth token
# https://www.eventbrite.com/platform/api
EVENTBRITE_API_KEY=

# ── Scraper / Playwright ─────────────────────────────────────
# Set to "false" to watch the browser while debugging selectors.
HEADLESS=true

# Optional: path to a system Chromium/Chrome binary, for hosts where the
# Playwright browser download isn't available (ARM boards, NAS boxes).
# CHROMIUM_PATH=/usr/bin/chromium

# How many scrapers run at once (default 3, max 8). Each scraper targets a
# different site, so this stays polite per-domain.
# SCRAPER_CONCURRENCY=3

# Polite delay (ms) between outbound requests within an adapter (default 350).
# REQUEST_DELAY_MS=350

# ── Scheduler ────────────────────────────────────────────────
# Cron expression for the recurring ingestion run (default: every 6 hours).
REFRESH_CRON=0 */6 * * *

# Run a full ingestion once on server startup (true/false).
REFRESH_ON_START=false
